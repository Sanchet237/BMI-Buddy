<?xml version="1.0" encoding="utf-8"?>
<!-- BMI Calculator main layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- Header with Logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_logo_circle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⚕"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                android:text="@string/app_title"
                android:textColor="#1A1A2E"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/app_subtitle"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Unit Toggle Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_toggle_container"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/btnMetric"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/metric_unit"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_toggle_selected"
                android:fontFamily="sans-serif-medium"
                android:contentDescription="Switch to metric units" />

            <TextView
                android:id="@+id/btnImperial"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/imperial_unit"
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif"
                android:contentDescription="Switch to imperial units" />
        </LinearLayout>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Height Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEIGHT"
                    android:textSize="11sp"
                    android:textColor="#00BFA5"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14" />

                <EditText
                    android:id="@+id/etHeightCm"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/height_cm_hint"
                    android:textColorHint="#C4C4C4"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:imeOptions="actionNext"
                    android:contentDescription="Height in centimeters" />

                <LinearLayout
                    android:id="@+id/layoutHeightImperial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etHeightFt"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="ft"
                        android:textColorHint="#C4C4C4"
                        android:inputType="number"
                        android:textColor="#1A1A2E"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:imeOptions="actionNext" />

                    <EditText
                        android:id="@+id/etHeightIn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field"
                        android:hint="in"
                        android:textColorHint="#C4C4C4"
                        android:inputType="numberDecimal"
                        android:textColor="#1A1A2E"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:imeOptions="actionNext" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHeightUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="centimeters"
                    android:textSize="11sp"
                    android:textColor="#C4C4C4" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#F3F4F6" />

                <!-- Weight Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEIGHT"
                    android:textSize="11sp"
                    android:textColor="#00BFA5"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14" />

                <EditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="e.g. 70"
                    android:textColorHint="#C4C4C4"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:imeOptions="actionDone" />

                <TextView
                    android:id="@+id/tvWeightUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="kilograms"
                    android:textSize="11sp"
                    android:textColor="#C4C4C4" />

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCalculate"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_calculate_button"
                        android:text="@string/calculate_btn"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:elevation="2dp"
                        android:contentDescription="Calculate BMI" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnClear"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outline_button"
                        android:text="@string/clear_btn"
                        android:textColor="#00BFA5"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:contentDescription="Clear all inputs" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR RESULT"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14" />

                <TextView
                    android:id="@+id/tvBmiValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textSize="64sp"
                    android:textColor="#00BFA5"
                    android:fontFamily="sans-serif-light" />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Normal Weight"
                    android:textSize="20sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvCategoryDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:lineSpacingExtra="3dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#F3F4F6" />

                <!-- BMI Scale -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI SCALE"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:orientation="horizontal"
                    android:clipToOutline="true"
                    android:background="@drawable/bg_scale_bar_container">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="185"
                        android:background="#5B9BD5" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="65"
                        android:background="#4CAF50" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="50"
                        android:background="#FF9800" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="100"
                        android:background="#F44336" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="185"
                        android:text="Under"
                        android:textSize="9sp"
                        android:textColor="#5B9BD5" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="65"
                        android:text="Normal"
                        android:textSize="9sp"
                        android:textColor="#4CAF50" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="50"
                        android:text="Over"
                        android:textSize="9sp"
                        android:textColor="#FF9800" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="100"
                        android:text="Obese"
                        android:textSize="9sp"
                        android:textColor="#F44336" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBmiScale"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:background="@android:color/transparent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#F3F4F6" />

                <!-- Statistics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_card"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HEALTHY RANGE"
                            android:textSize="9sp"
                            android:textColor="#9CA3AF"
                            android:letterSpacing="0.10" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="18.5 – 24.9"
                            android:textSize="16sp"
                            android:textColor="#4CAF50"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_card"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textSize="9sp"
                            android:textColor="#9CA3AF"
                            android:letterSpacing="0.10" />

                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="—"
                            android:textSize="16sp"
                            android:textColor="#00BFA5"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Result Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnInfo"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_outline_button"
                        android:text="ℹ What is BMI?"
                        android:textSize="12sp"
                        android:textColor="#00BFA5"
                        android:fontFamily="sans-serif-medium" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnShare"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outline_button"
                        android:text="↗ Share Result"
                        android:textSize="12sp"
                        android:textColor="#00BFA5"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BMI Reference -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI REFERENCE"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_blue"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Underweight"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Below 18.5"
                        android:textSize="13sp"
                        android:textColor="#5B9BD5"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_green"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Normal Weight"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18.5 – 24.9"
                        android:textSize="13sp"
                        android:textColor="#4CAF50"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_orange"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Overweight"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25.0 – 29.9"
                        android:textSize="13sp"
                        android:textColor="#FF9800"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_red"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Obese"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30.0 and above"
                        android:textSize="13sp"
                        android:textColor="#F44336"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="#E5E7EB" />

        <!-- Footer with Creator and Social Links -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/created_by"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/creator_name"
                android:textSize="16sp"
                android:textColor="#00BFA5"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="14dp">

                <ImageView
                    android:id="@+id/btnInstagram"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/insta"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/instagram_desc"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="18dp" />

                <ImageView
                    android:id="@+id/btnLinkedIn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/linkedin"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/linkedin_desc"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="18dp" />

                <ImageView
                    android:id="@+id/btnGithub"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/github"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/github_desc"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
